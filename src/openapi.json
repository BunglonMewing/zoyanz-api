{
  "openapi": "1.0.0",
  "info": {
    "title": "ZoYanz",
    "author": "Azor & Yanz",
    "version": "v1.0.0",
    "description": "Simple and easy to use API."
  },
  "servers": [
    { "url": "/" }
  ],
  "tags": [
    { "name": "AI" },
    { "name": "Anime" },
    { "name": "Downloader" },
    { "name": "Image" },
    { "name": "News" },
    { "name": "Search Tools" },
    { "name": "Maker" },
    { "name": "Random" },
    { "name": "Tools" }
  ],
  "paths": {
    "/ai/copilot": {
      "get": {
        "summary": "Copilot Chat",
        "description": "Kirim pertanyaan ke Copilot Microsoft dan dapatkan jawaban beserta referensi/citations",
        "tags": ["AI"],
        "parameters": [
          {
            "name": "message",
            "in": "query",
            "required": true,
            "description": "Pesan atau pertanyaan yang ingin dikirim ke Copilot",
            "schema": { "type": "string" }
          },
          {
            "name": "model",
            "in": "query",
            "required": false,
            "description": "Model Copilot yang digunakan (default: 'default', opsional: 'think-deeper', 'gpt-5')",
            "schema": { "type": "string", "enum": ["default", "think-deeper", "gpt-5"], "default": "default" }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mendapatkan jawaban dari Copilot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "text": { "type": "string", "example": "Berikut adalah berita terbaru dari Indonesia..." },
                    "citations": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "title": { "type": "string", "example": "Detik News" },
                          "icon": { "type": "string", "example": "https://example.com/icon.png" },
                          "url": { "type": "string", "format": "uri", "example": "https://www.detik.com/..." }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Request invalid, message kosong",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Message wajib diisi" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Gagal memproses request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Gagal memproses request" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ai/venice": {
      "get": {
        "summary": "Venice AI Chat",
        "description": "Mengirim pertanyaan ke model Venice AI dan mendapatkan jawaban final.",
        "tags": ["AI"],
        "parameters": [
          {
            "name": "message",
            "in": "query",
            "required": true,
            "description": "Teks atau pertanyaan yang ingin dikirim ke Venice AI",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mendapatkan jawaban dari Venice AI",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "result": {
                      "type": "string",
                      "example": "Halo! Saya Venice AI, siap membantu Anda menjawab pertanyaan atau membuat konten kreatif."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Request invalid, message kosong",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Pesan wajib diisi" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Gagal memproses request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Gagal memproses request" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/anime/waifu": {
      "get": {
        "summary": "Waifu",
        "description": "Mengambil gambar waifu secara acak dari API waifu.pics.",
        "tags": ["Anime"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Berhasil mengambil gambar waifu",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary",
                  "example": "Binary image data"
                }
              }
            }
          },
          "500": {
            "description": "Gagal memproses request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Gagal mengambil waifu." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/download/capcut": {
      "get": {
        "summary": "CapCut Downloader",
        "description": "Ambil data dan video template dari CapCut berdasarkan URL template",
        "tags": ["Downloader"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "description": "URL template CapCut yang ingin diambil datanya",
            "required": true,
            "schema": { "type": "string", "format": "uri" }
          }
        ],
        "responses": {
          "200": {
            "description": "Respon berhasil",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "result": {
                      "type": "object",
                      "properties": {
                        "title": { "type": "string", "example": "Template Name" },
                        "description": { "type": "string", "example": "Template Description" },
                        "thumbnail": { "type": "string", "format": "uri" },
                        "video": { "type": "string", "format": "uri" },
                        "author": { "type": "string", "example": "Author Name" },
                        "avatar": { "type": "string", "format": "uri" },
                        "duration": { "type": "number", "example": 15 },
                        "likes": { "type": "integer", "example": 1200 },
                        "uses": { "type": "integer", "example": 300 }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "URL tidak disertakan" },
          "500": { "description": "Gagal memproses request" }
        }
      }
    },
    "/download/mediafire": {
      "get": {
        "summary": "MediaFire Downloader",
        "description": "Mengambil informasi dan link download dari file MediaFire",
        "tags": ["Downloader"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "URL file MediaFire yang ingin di-download",
            "schema": {
              "type": "string",
              "format": "uri",
              "example": "https://www.mediafire.com/file/b89hlvgqub8uwhn/example.zip/file"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mendapatkan informasi file",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "creator": { "type": "string", "example": "Azor & Yanz" },
                    "result": {
                      "type": "object",
                      "properties": {
                        "meta": {
                          "type": "object",
                          "properties": {
                            "title": { "type": "string", "example": "MT MANAGER INI BUAT YANG ZArchiver nya error yaa .zip" },
                            "filename": { "type": "string", "example": "MT_MANAGER_INI_BUAT_YANG_ZArchiver_nya_error_yaa_.zip" },
                            "thumbnail": { "type": "string", "format": "uri", "example": "https://www.mediafire.com/thumb.jpg" },
                            "description": { "type": "string", "example": "Compressed Archive (.ZIP) - File size: 25.48MB" },
                            "file_size": { "type": "string", "example": "25.48MB" },
                            "upload_date": { "type": "string", "example": "2025-12-05 20:38:37" },
                            "file_type": { "type": "string", "example": "ZIP" }
                          }
                        },
                        "download": {
                          "type": "object",
                          "properties": {
                            "url": { "type": "string", "format": "uri", "example": "https://download.../file.zip" },
                            "size": { "type": "string", "example": "25.48MB" },
                            "mimetype": { "type": "string", "example": "application/zip" },
                            "direct_link": { "type": "string", "format": "uri", "example": "https://download.../file.zip" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "URL tidak valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "creator": { "type": "string", "example": "Azor & Yanz" },
                    "error": { "type": "string", "example": "URL harus dari MediaFire (mediafire.com)" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Gagal memproses request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "creator": { "type": "string", "example": "Azor & Yanz" },
                    "error": { "type": "string", "example": "Gagal mengambil data dari MediaFire: ..." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/download/pinterest": {
      "get": {
        "summary": "Pinterest Downloader",
        "description": "Mengambil data dan link media (video/image) dari URL Pinterest / pin.it.",
        "tags": ["Downloader"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "description": "URL Pinterest / pin.it yang ingin di-download",
            "required": true,
            "schema": {
              "type": "string",
              "example": "https://pin.it/lOPdveAO7"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mengambil data Pinterest",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "creator": { "type": "string", "example": "Z7:林企业" },
                    "result": {
                      "type": "object",
                      "properties": {
                        "type": { "type": "string", "example": "video" },
                        "title": { "type": "string", "example": "Art" },
                        "author": { "type": "string", "example": "ShiroAMV7" },
                        "username": { "type": "string", "example": "shiroamv7" },
                        "media": { "type": "string", "example": "https://v1.pinimg.com/videos/iht/expMp4/..." },
                        "pinterest_url": { "type": "string", "example": "https://pin.it/lOPdveAO7" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "URL tidak valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "creator": { "type": "string", "example": "Z7:林企业" },
                    "error": { "type": "string", "example": "URL harus dari Pinterest / pin.it" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Gagal memproses request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "creator": { "type": "string", "example": "Z7:林企业" },
                    "error": { "type": "string", "example": "Gagal memproses request" }
                  }
                }
              }
            }
          }
        }
      }
    },
