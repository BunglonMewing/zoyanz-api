    "/search/fdroid": {
      "get": {
        "summary": "Pencarian Aplikasi di F-Droid",
        "description": "Mencari aplikasi di repositori F-Droid berdasarkan kata kunci dan bahasa.",
        "tags": ["Search Tools"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Kata kunci pencarian aplikasi (contoh: termux, browser, game)",
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "Kode bahasa untuk hasil (contoh: id untuk Indonesia, en untuk Inggris). Default: id",
            "schema": {
              "type": "string",
              "default": "id",
              "enum": ["id", "en"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hasil pencarian berhasil didapatkan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": true
                    },
                    "query": {
                      "type": "string",
                      "example": "termux"
                    },
                    "language": {
                      "type": "string",
                      "example": "id"
                    },
                    "total": {
                      "type": "integer",
                      "example": 18
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string",
                            "example": "Termux:Styling"
                          },
                          "description": {
                            "type": "string",
                            "example": "Sesuaikan terminal Termux Anda"
                          },
                          "license": {
                            "type": "string",
                            "example": "GPL-3.0-only"
                          },
                          "link": {
                            "type": "string",
                            "format": "uri",
                            "example": "https://f-droid.org/id/packages/com.termux.styling"
                          },
                          "icon": {
                            "type": "string",
                            "format": "uri",
                            "example": "https://f-droid.org/assets/ic_repo_app_default.png"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Parameter 'q' tidak boleh kosong"
          },
          "500": {
            "description": "Gagal mengambil data dari F-Droid"
          }
        }
      }
    },
    "/search/transfermarkt": {
      "get": {
        "summary": "Pencarian Pemain Transfermarkt",
        "description": "Mencari pemain sepak bola di Transfermarkt berdasarkan nama. Menampilkan hasil pencarian dan detail pemain pertama.",
        "tags": ["Search Tools"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Nama pemain yang dicari (contoh: Ronaldo, Messi, Mbappe)",
            "schema": {
              "type": "string",
              "example": "Ronaldo"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Data pemain berhasil didapatkan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "creator": { "type": "string", "example": "Azor & Yanz" },
                    "query": { "type": "string", "example": "Ronaldo" },
                    "result": {
                      "type": "object",
                      "properties": {
                        "search": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "name": { "type": "string", "example": "Cristiano Ronaldo" },
                              "position": { "type": "string", "example": "Striker" },
                              "age": { "type": "string", "example": "39" },
                              "club": { "type": "string", "example": "Al-Nassr FC" },
                              "nationality": { "type": "string", "example": "Portugal" },
                              "marketValue": { "type": "string", "example": "€15.00m" },
                              "image": { "type": "string", "format": "uri" },
                              "detailUrl": { "type": "string", "format": "uri" },
                              "id": { "type": "string", "example": "8198" }
                            }
                          }
                        },
                        "detail": {
                          "type": "object",
                          "properties": {
                            "id": { "type": "string", "example": "8198" },
                            "name": { "type": "string", "example": "Cristiano Ronaldo" },
                            "image": { "type": "string", "format": "uri" },
                            "club": { "type": "string", "example": "Al-Nassr FC" },
                            "clubLogo": { "type": "string", "format": "uri" },
                            "fullName": { "type": "string", "example": "Cristiano Ronaldo dos Santos Aveiro" },
                            "age": { "type": "string", "example": "39 tahun" },
                            "birthplace": { "type": "string", "example": "Funchal" },
                            "height": { "type": "string", "example": "1,87 m" },
                            "nationality": { "type": "string", "example": "Portugal" },
                            "position": { "type": "string", "example": "Striker" },
                            "foot": { "type": "string", "example": "Kanan" },
                            "agent": { "type": "string", "example": "Gestifute" },
                            "joined": { "type": "string", "example": "1 Jan 2023" },
                            "contract": { "type": "string", "example": "30 Jun 2025" },
                            "marketValue": { "type": "string", "example": "€15.00m" },
                            "stats": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "competition": { "type": "string" },
                                  "apps": { "type": "string" },
                                  "goals": { "type": "string" },
                                  "assists": { "type": "string" }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Parameter 'q' tidak boleh kosong",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Parameter 'q' (nama pemain) wajib diisi" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Gagal mengambil data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Pemain dengan nama 'Ronaldo' tidak ditemukan" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/search/transfermarkt/list": {
