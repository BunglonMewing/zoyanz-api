                          "age": { "type": "string" },
                          "club": { "type": "string" },
                          "nationality": { "type": "string" },
                          "marketValue": { "type": "string" },
                          "image": { "type": "string", "format": "uri" },
                          "detailUrl": { "type": "string", "format": "uri" },
                          "id": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Parameter 'q' tidak boleh kosong"
