          "500": {
            "description": "Gagal mengambil data"
          }
        }
      }
    },
    "/search/wikipedia": {
      "get": {
        "summary": "Pencarian Wikipedia",
        "description": "Mencari artikel di Wikipedia Bahasa Indonesia. Bisa memilih mode simple (ringkasan) atau deep (artikel lengkap)",
        "tags": ["Search Tools"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Kata kunci pencarian (judul artikel)",
            "schema": {
              "type": "string",
              "example": "Jokowi"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "description": "Mode pencarian: 'simple' untuk ringkasan (default), 'deep' untuk artikel lengkap",
            "schema": {
              "type": "string",
              "enum": ["simple", "deep"],
              "default": "simple"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hasil pencarian berhasil",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "creator": { "type": "string", "example": "Azor & Yanz" },
                    "query": { "type": "string", "example": "Jokowi" },
                    "mode": { "type": "string", "example": "simple" },
                    "result": {
                      "type": "object",
                      "properties": {
                        "status": { "type": "string", "example": "success" },
                        "type": { "type": "string", "example": "simple" },
                        "title": { "type": "string", "example": "Joko Widodo" },
                        "url": { "type": "string", "example": "https://id.wikipedia.org/wiki/Joko_Widodo" },
                        "thumbnail": { "type": "string", "example": "https://upload.wikimedia.org/..." },
                        "summary": { "type": "string", "example": "Joko Widodo adalah Presiden Indonesia ke-7..." },
                        "search_results": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "title": { "type": "string" },
                              "snippet": { "type": "string" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Parameter 'q' tidak boleh kosong"
          },
          "500": {
            "description": "Gagal mengambil data dari Wikipedia"
          }
        }
      }
    },
    "/search/wikipedia/list": {
      "get": {
        "summary": "Daftar Pencarian Wikipedia",
