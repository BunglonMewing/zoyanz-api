    "/maker/brat": {
      "get": {
        "summary": "Brat Text to Image Generator",
        "description": "Membuat gambar dengan teks khas style BRAT (langsung mengembalikan file gambar)",
        "tags": ["Maker"],
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "required": true,
            "description": "Teks yang akan diubah menjadi gambar BRAT",
            "schema": {
              "type": "string",
              "example": "apacoba"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil membuat gambar",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Parameter 'text' tidak disertakan",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Parameter \"text\" wajib diisi"
                }
              }
            }
          },
          "500": {
            "description": "Gagal memproses request",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Error: Gagal memproses request"
                }
              }
            }
          }
        }
      }
    },
