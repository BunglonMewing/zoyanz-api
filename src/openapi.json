    "/tools/catbox": {
      "post": {
        "summary": "Upload File ke Catbox",
        "description": "Upload file ke Catbox.moe dan mendapatkan URL publik. Mendukung berbagai format file.",
        "tags": ["Tools"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "File yang akan diupload (max 200MB)"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File berhasil diupload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "creator": { "type": "string", "example": "Azor & Yanz" },
                    "result": {
                      "type": "object",
                      "properties": {
                        "url": { "type": "string", "format": "uri", "example": "https://files.catbox.moe/xxxxxx.jpg" },
                        "filename": { "type": "string", "example": "gambar.jpg" },
                        "size": { "type": "integer", "example": 123456 },
                        "mimetype": { "type": "string", "example": "image/jpeg" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Tidak ada file yang diupload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "creator": { "type": "string", "example": "Azor & Yanz" },
                    "error": { "type": "string", "example": "Tidak ada file yang diupload. Pastikan field name 'file'" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Gagal upload ke Catbox",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "creator": { "type": "string", "example": "Azor & Yanz" },
                    "error": { "type": "string", "example": "Gagal upload ke Catbox" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}